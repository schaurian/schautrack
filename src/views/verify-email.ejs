<%- include('partials/header', { title: 'Verify Email' }) %>
  <section class="panel">
    <div class="panel-header">
      <div>
        <p class="eyebrow">Account verification</p>
        <h1>Verify email</h1>
      </div>
      <a href="/login" class="ghost">Back to login</a>
    </div>
    <% if (error) { %>
      <div class="alert danger"><%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="stack">
        <div class="alert success"><%= success %></div>
        <a href="/login" class="primary">Go to login</a>
      </div>
    <% } else { %>
      <p class="muted">If <strong><%= email %></strong> is a valid address, we've sent a 6-digit code. Check your spam folder if you don't see it.</p>
      <form action="/verify-email" method="POST" class="stack">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <label class="field">
          <span>Verification code</span>
          <input type="text" name="code" inputmode="numeric" pattern="[0-9]*" maxlength="6" placeholder="123456" required autocomplete="off" autofocus>
        </label>
        <button type="submit" class="primary">Verify email</button>
      </form>
      <form action="/verify-email/resend" method="POST" class="stack" style="margin-top: var(--space-md);">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <% if (captchaSvg) { %>
          <div><%- captchaSvg %></div>
          <label class="field">
            <span>Captcha</span>
            <input type="text" name="captcha" required autocomplete="off" placeholder="Enter the text above">
          </label>
        <% } %>
        <button type="submit" class="ghost" id="resend-btn">Resend code</button>
      </form>
      <script>
        (function() {
          var btn = document.getElementById('resend-btn');
          var cooldown = 300;
          var key = 'resendCooldownUntil';
          var until = parseInt(sessionStorage.getItem(key) || '0', 10);
          var now = Date.now();
          if (until > now) {
            startCountdown(Math.ceil((until - now) / 1000));
          }
          btn.closest('form').addEventListener('submit', function() {
            sessionStorage.setItem(key, String(Date.now() + cooldown * 1000));
          });
          function startCountdown(seconds) {
            btn.disabled = true;
            update(seconds);
            var iv = setInterval(function() {
              seconds--;
              if (seconds <= 0) {
                clearInterval(iv);
                btn.disabled = false;
                btn.textContent = 'Resend code';
                sessionStorage.removeItem(key);
              } else {
                update(seconds);
              }
            }, 1000);
          }
          function update(s) {
            var m = Math.floor(s / 60);
            var sec = s % 60;
            btn.textContent = 'Resend code (' + m + ':' + (sec < 10 ? '0' : '') + sec + ')';
          }
        })();
      </script>
    <% } %>
  </section>
<%- include('partials/footer') %>
