<%- include('partials/header', { title: 'Settings' }) %>
  <section class="grid two">
    <div class="panel">
      <div class="panel-header">
        <div>
          <h2>Nutrition goals</h2>
        </div>
      </div>
      <form action="/settings/macros" method="POST" class="stack">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <p class="muted small">Enable the nutrients you want to track. Goals are optional. Choose whether each is a limit (stay under) or target (try to reach).</p>
        <div class="macro-settings">
          <% const goals = user.macro_goals || {};
             const defaultModes = { calories: 'limit', protein: 'target', carbs: 'limit', fat: 'limit', fiber: 'target', sugar: 'limit' };
             const allNutrients = [
               { key: 'calories', label: 'Calories', unit: 'kcal', max: 99999, fieldName: 'calorie_goal',
                 enabled: (user.macros_enabled || {}).calories !== false,
                 goal: goals.calories != null ? goals.calories : user.daily_goal,
                 mode: goals.calories_mode || defaultModes.calories },
               { key: 'protein', label: 'Protein', unit: 'g', max: 9999 },
               { key: 'carbs', label: 'Carbs', unit: 'g', max: 9999 },
               { key: 'fat', label: 'Fat', unit: 'g', max: 9999 },
               { key: 'fiber', label: 'Fiber', unit: 'g', max: 9999 },
               { key: 'sugar', label: 'Sugar', unit: 'g', max: 9999 },
             ];
          %>
          <% allNutrients.forEach((n) => {
            const enabled = n.enabled !== undefined ? n.enabled : (user.macros_enabled || {})[n.key] === true;
            const goal = n.goal !== undefined ? n.goal : goals[n.key];
            const mode = n.mode || goals[`${n.key}_mode`] || defaultModes[n.key] || 'limit';
            const fieldName = n.fieldName || `${n.key}_goal`;
          %>
            <div class="macro-row <%= enabled ? '' : 'macro-row--off' %>" data-nutrient="<%= n.key %>">
              <label class="macro-toggle">
                <input type="checkbox" name="<%= n.key %>_enabled" <%= enabled ? 'checked' : '' %> data-macro-toggle="<%= n.key %>">
                <span class="macro-label"><%= n.label %></span>
              </label>
              <div class="macro-row-fields <%= !enabled ? 'disabled' : '' %>" data-macro-goal="<%= n.key %>" data-macro-mode="<%= n.key %>">
                <span class="input-unit-wrap">
                  <input type="number" name="<%= fieldName %>" min="0" max="<%= n.max %>"
                         placeholder="Goal" value="<%= goal || '' %>" <%= !enabled ? 'disabled' : '' %>>
                  <span class="input-unit"><%= n.unit %></span>
                </span>
                <select name="<%= n.key %>_mode" <%= !enabled ? 'disabled' : '' %>>
                  <option value="limit" <%= mode === 'limit' ? 'selected' : '' %>>Limit</option>
                  <option value="target" <%= mode === 'target' ? 'selected' : '' %>>Target</option>
                </select>
              </div>
            </div>
          <% }) %>
        </div>
        <%
          const autoCalcEnabled = (user.macros_enabled || {}).auto_calc_calories === true;
          const caloriesOn = (user.macros_enabled || {}).calories !== false;
          const proteinOn = (user.macros_enabled || {}).protein === true;
          const carbsOn = (user.macros_enabled || {}).carbs === true;
          const fatOn = (user.macros_enabled || {}).fat === true;
          const canAutoCalc = caloriesOn && proteinOn && carbsOn && fatOn;
        %>
        <div class="macro-row <%= !autoCalcEnabled ? 'macro-row--off' : '' %>" style="border-color: rgba(14, 165, 233, 0.2); background: rgba(14, 165, 233, 0.04);" data-auto-calc-row>
          <label class="macro-toggle">
            <input type="checkbox" name="auto_calc_calories" <%= autoCalcEnabled ? 'checked' : '' %> data-auto-calc-toggle>
            <span class="macro-label" style="color: var(--accent);">Auto-calculate calories</span>
          </label>
          <div class="macro-row-fields">
            <span class="muted small">P×4 + C×4 + F×9</span>
          </div>
        </div>
        <div class="macro-row" style="border-color: rgba(245, 158, 11, 0.2); background: rgba(245, 158, 11, 0.04);">
          <span class="macro-label" style="color: #fcd34d;">Threshold</span>
          <div class="macro-row-fields">
            <span style="position: relative; display: inline-flex; align-items: center; width: 80px;">
              <input type="number" name="goal_threshold" min="0" max="99" value="<%= user.goal_threshold != null ? user.goal_threshold : 10 %>" style="width: 100%; padding-right: 24px;">
              <span class="muted" style="position: absolute; right: 10px; font-size: 0.85rem; pointer-events: none;">%</span>
            </span>
          </div>
        </div>
        <p class="muted small">Green on target. Yellow within threshold. Red beyond it.</p>
      </form>
    </div>

    <div class="settings-right-stack">
      <div class="panel">
        <div class="panel-header">
          <div>
            <h2>Preferences</h2>
          </div>
        </div>
        <form action="/settings/preferences" method="POST" class="stack compact">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="field">
            <span>Timezone</span>
            <select name="timezone" class="timezone-select">
              <% timezones.forEach((tz) => { %>
                <option value="<%= tz %>" <%= (user.timezone || 'UTC') === tz ? 'selected' : '' %>><%= tz %></option>
              <% }) %>
            </select>
            <p class="muted small">Affects how timestamps display across the app.</p>
          </div>
          <div class="field">
            <span>Preferred weight unit</span>
            <div class="pill-group" data-weight-unit>
              <label class="pill <%= (user.weight_unit || 'lb') === 'lb' ? 'active' : '' %>">
                <input type="radio" name="weight_unit" value="lb" <%= (user.weight_unit || 'lb') === 'lb' ? 'checked' : '' %>> Pounds (lb)
              </label>
              <label class="pill <%= user.weight_unit === 'kg' ? 'active' : '' %>">
                <input type="radio" name="weight_unit" value="kg" <%= user.weight_unit === 'kg' ? 'checked' : '' %>> Kilograms (kg)
              </label>
            </div>
            <p class="muted small">Affects how weights display across the app.</p>
          </div>
        </form>
      </div>
      <div class="panel settings-right-grow">
        <div class="panel-header">
          <div>
            <h2>Two-factor</h2>
          </div>
        </div>
        <div class="stack totp-content">
          <% if (user.totp_enabled) { %>
            <div class="alert success">2FA is enabled.</div>
            <form action="/2fa/disable" method="POST" class="stack compact">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <label class="field">
                <span>Current 2FA code</span>
                <input type="text" name="token" inputmode="numeric" pattern="[0-9]*" required placeholder="123456">
              </label>
              <button type="submit" class="ghost danger full">Disable 2FA</button>
            </form>
          <% } else if (hasTempSecret) { %>
            <p class="muted small">Scan the QR code or copy the secret, then enter the 6-digit code.</p>
            <div class="totp-setup">
              <div class="qr-center">
                <% if (qrDataUrl) { %>
                  <img src="<%= qrDataUrl %>" alt="2FA QR code" id="qr-img" style="cursor: pointer;" title="Click to enlarge">
                <% } %>
                <% if (otpauthUrl) { %>
                  <button type="button" class="ghost full" id="copy-totp-url">Copy setup URL</button>
                  <script>
                    document.getElementById('copy-totp-url').addEventListener('click', async function() {
                      const url = <%- JSON.stringify(otpauthUrl) %>;
                      try {
                        await navigator.clipboard.writeText(url);
                        this.textContent = 'Copied!';
                        setTimeout(() => { this.textContent = 'Copy setup URL'; }, 1500);
                      } catch (err) {
                        console.error('Copy failed', err);
                      }
                    });
                  </script>
                <% } %>
              </div>
              <form action="/2fa/enable" method="POST" class="stack compact">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <label class="field">
                  <span>6-digit code</span>
                  <input type="text" name="token" inputmode="numeric" pattern="[0-9]*" required placeholder="123456">
                </label>
                <button type="submit" class="primary full">Activate 2FA</button>
                <button type="submit" class="ghost danger full" formaction="/2fa/cancel" formnovalidate>Cancel</button>
              </form>
            </div>
          <% } else { %>
            <p class="muted small">Add extra security with an authenticator app.</p>
            <form action="/2fa/setup" method="POST">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button type="submit" class="primary full">Start setup</button>
            </form>
          <% } %>
        </div>
      </div>
    </div>
  </section>

  <section class="grid two">
    <div class="panel">
      <div class="panel-header">
        <div>
          <h2>Change password</h2>
        </div>
      </div>
      <% if (passwordFeedback) { %>
        <div class="alert <%= passwordFeedback.type === 'error' ? 'danger' : 'success' %>"><%= passwordFeedback.message %></div>
      <% } %>
      <form action="/settings/password" method="POST" class="stack">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <label class="field">
          <span>Current password</span>
          <input type="password" name="current_password" required autocomplete="current-password">
        </label>
        <label class="field">
          <span>New password</span>
          <input type="password" name="new_password" required autocomplete="new-password" minlength="6">
        </label>
        <label class="field">
          <span>Confirm new password</span>
          <input type="password" name="confirm_password" required autocomplete="new-password" minlength="6">
        </label>
        <% if (user.totp_enabled) { %>
          <label class="field">
            <span>2FA code</span>
            <input type="text" name="totp_code" required autocomplete="one-time-code" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" placeholder="6-digit code">
          </label>
        <% } %>
        <button type="submit" class="primary">Update password</button>
      </form>
    </div>

    <div class="panel">
      <div class="panel-header">
        <div>
          <h2>Change email</h2>
        </div>
      </div>
      <p class="muted small">Current email: <strong><%= user.email %></strong></p>
      <% if (emailFeedback) { %>
        <div class="alert <%= emailFeedback.type === 'error' ? 'danger' : 'success' %>"><%= emailFeedback.message %></div>
      <% } %>
      <form action="/settings/email/request" method="POST" class="stack">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <label class="field">
          <span>New email address</span>
          <input type="email" name="new_email" required autocomplete="email" placeholder="newemail@example.com">
        </label>
        <label class="field">
          <span>Current password</span>
          <input type="password" name="password" required autocomplete="current-password">
        </label>
        <% if (user.totp_enabled) { %>
          <label class="field">
            <span>2FA code</span>
            <input type="text" name="totp_code" required autocomplete="one-time-code" inputmode="numeric" pattern="[0-9]{6}" maxlength="6" placeholder="6-digit code">
          </label>
        <% } %>
        <button type="submit" class="primary">Send verification code</button>
      </form>
    </div>
  </section>

  <section class="panel">
    <div class="panel-header">
      <div>
        <h2>Link accounts</h2>
      </div>
      <div class="chip muted">Up to <%= maxLinks %></div>
    </div>

    <div data-link-feedback>
    <% if (linkFeedback) { %>
      <div class="alert <%= linkFeedback.type === 'error' ? 'danger' : 'success' %>"><%= linkFeedback.message %></div>
    <% } %>
    </div>

    <form action="/settings/link/request" method="POST" class="stack link-form" data-link-request-form>
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <label class="field">
        <span>Invite by email</span>
        <input type="email" name="email" placeholder="friend@example.com" required <%= availableSlots === 0 ? 'disabled' : '' %>>
      </label>
      <div class="muted small" data-link-slots>
        Linked accounts: <%= maxLinks - availableSlots %>/<%= maxLinks %>. <%= availableSlots === 0 ? 'Remove one to invite another.' : `You can invite ${availableSlots} more.` %>
      </div>
      <div>
        <button type="submit" class="primary" <%= availableSlots === 0 ? 'disabled' : '' %>>Send request</button>
      </div>
    </form>

    <div class="grid two">
      <div class="table" data-incoming-table>
        <div class="table-row header linked-row">
          <div>Incoming requests</div>
          <div></div>
        </div>
        <% if (!incomingRequests || incomingRequests.length === 0) { %>
          <div class="table-row linked-row" data-link-empty="incoming">
            <div class="muted small">No incoming requests.</div>
            <div></div>
          </div>
        <% } else { %>
          <% incomingRequests.forEach((req) => { %>
            <div class="table-row linked-row" data-link-row="<%= req.id %>">
              <div>
                <div class="table-email"><%= req.email %></div>
                <div class="muted small">Requested <%= req.created_at ? req.created_at.toISOString().slice(0,10) : '' %></div>
              </div>
              <div class="table-actions">
                <form action="/settings/link/respond" method="POST" class="inline-form" data-link-action>
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <input type="hidden" name="request_id" value="<%= req.id %>">
                  <input type="hidden" name="action" value="accept">
                  <button type="submit" class="primary">Accept</button>
                </form>
                <form action="/settings/link/respond" method="POST" class="inline-form" data-link-action>
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <input type="hidden" name="request_id" value="<%= req.id %>">
                  <input type="hidden" name="action" value="decline">
                  <button type="submit" class="ghost danger">Decline</button>
                </form>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>

      <div class="table" data-outgoing-table>
        <div class="table-row header linked-row">
          <div>Sent requests</div>
          <div></div>
        </div>
        <% if (!outgoingRequests || outgoingRequests.length === 0) { %>
          <div class="table-row linked-row" data-link-empty="outgoing">
            <div class="muted small">No pending requests.</div>
            <div></div>
          </div>
        <% } else { %>
          <% outgoingRequests.forEach((req) => { %>
            <div class="table-row linked-row" data-link-row="<%= req.id %>">
              <div>
                <div class="table-email"><%= req.email %></div>
                <div class="muted small">Sent <%= req.created_at ? req.created_at.toISOString().slice(0,10) : '' %></div>
              </div>
              <div class="table-actions">
                <form action="/settings/link/remove" method="POST" class="inline-form" data-link-action>
                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                  <input type="hidden" name="link_id" value="<%= req.id %>">
                  <button type="submit" class="ghost danger">Cancel</button>
                </form>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>

    <div class="table" style="margin-top: 14px;" data-accepted-table>
      <div class="table-row header linked-row">
        <div>Linked accounts</div>
        <div></div>
      </div>
      <% if (!acceptedLinks || acceptedLinks.length === 0) { %>
        <div class="table-row" data-link-empty="accepted">
          <div class="muted">No linked accounts yet.</div>
          <div></div>
          <div></div>
        </div>
      <% } else { %>
        <% acceptedLinks.forEach((link) => { %>
          <div class="table-row linked-row" data-link-row="<%= link.linkId %>">
            <div class="table-email"><%= link.email %></div>
            <div style="text-align: right;">
              <form action="/settings/link/remove" method="POST" class="inline-form" data-link-action>
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <input type="hidden" name="link_id" value="<%= link.linkId %>">
                <button type="submit" class="ghost danger">Remove</button>
              </form>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>
  </section>

  <section class="grid two">
    <div class="panel">
      <div class="panel-header">
        <div>
          <h2>AI settings</h2>
        </div>
      </div>
      <% if (aiFeedback) { %>
        <div class="alert <%= aiFeedback.type === 'error' ? 'danger' : 'success' %>"><%= aiFeedback.message %></div>
      <% } %>
      <form action="/settings/ai" method="POST" class="stack" id="ai-form">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <p class="muted small">Enter your own API key to use AI photo estimation.</p>
        <label class="field">
          <span>Provider</span>
          <select name="ai_provider" id="ai-provider-select">
            <option value="" <%= !user.preferred_ai_provider ? 'selected' : '' %>>— Select —</option>
            <option value="openai" <%= user.preferred_ai_provider === 'openai' ? 'selected' : '' %>>OpenAI</option>
            <option value="claude" <%= user.preferred_ai_provider === 'claude' ? 'selected' : '' %>>Claude</option>
            <option value="ollama" <%= user.preferred_ai_provider === 'ollama' ? 'selected' : '' %>>Ollama</option>
          </select>
        </label>
        <label class="field" id="ai-key-field">
          <span>API key</span>
          <input type="password" name="ai_key" placeholder="<%= user.hasAiKey ? '••••' + user.aiKeyLast4 : 'sk-...' %>" autocomplete="off">
        </label>
        <label class="field">
          <span>Model</span>
          <input type="text" name="ai_model" value="<%= user.ai_model || '' %>" placeholder="e.g. gpt-4o, claude-sonnet-4-5-20250929" autocomplete="off">
        </label>
        <label class="field">
          <span>Daily limit</span>
          <input type="number" name="ai_daily_limit" min="0" value="<%= user.ai_daily_limit || '' %>" placeholder="Unlimited">
        </label>
        <p class="muted small" id="ollama-hint" style="display: none;">Ollama endpoint must be configured by the server admin. API key is optional.</p>
        <button type="submit" class="primary">Save AI settings</button>
        <% const hasAnyAiSetting = user.hasAiKey || user.ai_model || user.ai_daily_limit || user.preferred_ai_provider; %>
        <% if (hasAnyAiSetting) { %>
          <button type="submit" name="clear_settings" value="true" class="ghost danger">Clear AI settings</button>
        <% } %>
      </form>
    </div>

    <div class="panel">
      <div class="panel-header">
        <div>
          <h2>Data &amp; account</h2>
        </div>
      </div>
      <% if (importFeedback) { %>
        <div class="alert <%= importFeedback.type === 'error' ? 'danger' : 'success' %>"><%= importFeedback.message %></div>
      <% } %>
      <div class="data-actions">
        <form action="/settings/export" method="GET" class="data-card stack">
          <p class="muted">Download your entries and goal as JSON.</p>
          <button type="submit" class="primary full">Export JSON</button>
        </form>
        <form id="import-form" action="/settings/import" method="POST" enctype="multipart/form-data" class="data-card stack">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <p class="muted danger-text">Import a saved export (.json). This will delete all current entries and replace them with the file.</p>
          <input class="file-input" type="file" name="import_file" accept="application/json" required hidden>
          <button type="button" class="primary full" id="import-btn">Import JSON</button>
        </form>
      </div>
      <div class="data-card stack danger-card spaced-top">
        <p class="muted">Need to delete your account? You can request deletion without logging in.</p>
        <a class="ghost danger full" href="/delete">Open deletion request page</a>
      </div>
    </div>
  </section>

  <script>
    (() => {
      const csrfToken = '<%= csrfToken %>';

      // --- AI provider toggle ---
      const aiProviderSelect = document.getElementById('ai-provider-select');
      const ollamaHint = document.getElementById('ollama-hint');
      const aiKeyField = document.getElementById('ai-key-field');
      if (aiProviderSelect) {
        function updateAiFields() {
          const isOllama = aiProviderSelect.value === 'ollama';
          ollamaHint.style.display = isOllama ? '' : 'none';
        }
        aiProviderSelect.addEventListener('change', updateAiFields);
        updateAiFields();
      }

      // --- Autosave helper ---
      function autosave(form, debounceMs) {
        let timer = null;
        const indicator = document.createElement('span');
        indicator.className = 'autosave-indicator';
        form.appendChild(indicator);

        function save() {
          // Re-enable disabled fields so values are included
          const disabled = Array.from(form.querySelectorAll('input:disabled, select:disabled'));
          disabled.forEach(el => el.disabled = false);
          const data = new URLSearchParams(new FormData(form));
          disabled.forEach(el => el.disabled = true);

          indicator.textContent = 'Saving…';
          indicator.classList.add('visible');
          indicator.classList.remove('error');

          fetch(form.action, {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'Accept': 'application/json', 'X-CSRF-Token': csrfToken },
            body: data
          }).then(r => {
            if (!r.ok) throw new Error(r.status);
            indicator.textContent = 'Saved';
            setTimeout(() => indicator.classList.remove('visible'), 1200);
          }).catch(() => {
            indicator.textContent = 'Save failed';
            indicator.classList.add('error');
            setTimeout(() => indicator.classList.remove('visible', 'error'), 2500);
          });
        }

        function trigger() {
          clearTimeout(timer);
          timer = setTimeout(save, debounceMs);
        }

        return trigger;
      }

      // --- Nutrition goals autosave ---
      const macroForm = document.querySelector('form[action="/settings/macros"]');
      if (macroForm) {
        const triggerMacroSave = autosave(macroForm, 600);
        macroForm.addEventListener('input', triggerMacroSave);
        macroForm.addEventListener('change', triggerMacroSave);
        macroForm.addEventListener('submit', (e) => e.preventDefault());
      }

      // --- Preferences autosave ---
      const prefForm = document.querySelector('form[action="/settings/preferences"]');
      if (prefForm) {
        const triggerPrefSave = autosave(prefForm, 600);
        prefForm.addEventListener('change', triggerPrefSave);
        prefForm.addEventListener('submit', (e) => e.preventDefault());
      }

      // --- Auto-calc toggle management ---
      const autoCalcToggle = document.querySelector('[data-auto-calc-toggle]');
      const autoCalcRow = document.querySelector('[data-auto-calc-row]');

      function updateAutoCalcAvailability() {
        if (!autoCalcToggle || !autoCalcRow) return;
        const cal = document.querySelector('[data-macro-toggle="calories"]');
        const pro = document.querySelector('[data-macro-toggle="protein"]');
        const carb = document.querySelector('[data-macro-toggle="carbs"]');
        const fat = document.querySelector('[data-macro-toggle="fat"]');
        const canEnable = (!cal || cal.checked) && pro && pro.checked && carb && carb.checked && fat && fat.checked;
        if (!canEnable && autoCalcToggle.checked) {
          autoCalcToggle.checked = false;
          autoCalcRow.classList.add('macro-row--off');
        }
      }

      // --- Macro toggle handling ---
      document.querySelectorAll('[data-macro-toggle]').forEach((checkbox) => {
        checkbox.addEventListener('change', () => {
          const row = checkbox.closest('.macro-row');
          const fieldsWrap = row && row.querySelector('.macro-row-fields');
          if (!fieldsWrap) return;
          if (checkbox.checked) {
            row.classList.remove('macro-row--off');
            fieldsWrap.classList.remove('disabled');
            fieldsWrap.querySelectorAll('input, select').forEach(el => el.disabled = false);
          } else {
            row.classList.add('macro-row--off');
            fieldsWrap.classList.add('disabled');
            fieldsWrap.querySelectorAll('input, select').forEach(el => el.disabled = true);
          }
          updateAutoCalcAvailability();
        });
      });

      function enableMacroToggle(key) {
        const cb = document.querySelector('[data-macro-toggle="' + key + '"]');
        if (!cb || cb.checked) return;
        cb.checked = true;
        const row = cb.closest('.macro-row');
        const fieldsWrap = row && row.querySelector('.macro-row-fields');
        if (row) row.classList.remove('macro-row--off');
        if (fieldsWrap) {
          fieldsWrap.classList.remove('disabled');
          fieldsWrap.querySelectorAll('input, select').forEach(el => el.disabled = false);
        }
      }

      if (autoCalcToggle) {
        autoCalcToggle.addEventListener('change', () => {
          if (autoCalcToggle.checked) {
            autoCalcRow.classList.remove('macro-row--off');
            // Auto-enable required nutrients
            ['calories', 'protein', 'carbs', 'fat'].forEach(enableMacroToggle);
          } else {
            autoCalcRow.classList.add('macro-row--off');
          }
        });
      }

      // --- Weight unit pill styling ---
      const unitGroup = document.querySelector('[data-weight-unit]');
      if (unitGroup) {
        unitGroup.addEventListener('change', (evt) => {
          if (evt.target.name !== 'weight_unit') return;
          unitGroup.querySelectorAll('.pill').forEach((pill) => pill.classList.remove('active'));
          const label = evt.target.closest('.pill');
          if (label) label.classList.add('active');
        });
      }

      // --- Import form ---
      const importForm = document.getElementById('import-form');
      const importBtn = document.getElementById('import-btn');
      const importFile = importForm ? importForm.querySelector('input[name="import_file"]') : null;
      if (importBtn && importFile) {
        importBtn.addEventListener('click', () => importFile.click());
        importFile.addEventListener('change', () => {
          if (!importFile.files.length) return;
          const ok = confirm('Importing will DELETE all current entries and replace them with "' + importFile.files[0].name + '". Continue?');
          if (ok) {
            importForm.submit();
          } else {
            importFile.value = '';
          }
        });
      }

      // --- Copy button for TOTP secret ---
      document.querySelectorAll('[data-copy]').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const text = btn.getAttribute('data-copy');
          try {
            await navigator.clipboard.writeText(text);
            const original = btn.textContent;
            btn.textContent = 'Copied!';
            setTimeout(() => btn.textContent = original, 1500);
          } catch (err) {
            console.error('Copy failed', err);
          }
        });
      });

      // --- QR code lightbox ---
      const qrImg = document.getElementById('qr-img');
      if (qrImg) {
        qrImg.addEventListener('click', () => {
          const overlay = document.createElement('div');
          overlay.className = 'qr-lightbox';
          const img = document.createElement('img');
          img.src = qrImg.src;
          overlay.appendChild(img);
          overlay.addEventListener('click', () => overlay.remove());
          document.body.appendChild(overlay);
        });
      }

      // --- Link actions (accept/decline/remove/request) via fetch ---
      const linkFeedbackEl = document.querySelector('[data-link-feedback]');
      const maxLinks = <%= maxLinks %>;

      function showLinkFeedback(type, message) {
        if (!linkFeedbackEl) return;
        linkFeedbackEl.innerHTML = '<div class="alert ' + (type === 'error' ? 'danger' : 'success') + '">' +
          message.replace(/</g, '&lt;') + '</div>';
        setTimeout(() => { linkFeedbackEl.innerHTML = ''; }, 3000);
      }

      function updateLinkSlots() {
        const slotsEl = document.querySelector('[data-link-slots]');
        const submitBtn = document.querySelector('[data-link-request-form] button[type="submit"]');
        const emailInput = document.querySelector('[data-link-request-form] input[name="email"]');
        if (!slotsEl) return;
        const accepted = document.querySelectorAll('[data-accepted-table] [data-link-row]').length;
        const available = maxLinks - accepted;
        if (available === 0) {
          slotsEl.textContent = 'Linked accounts: ' + accepted + '/' + maxLinks + '. Remove one to invite another.';
          if (submitBtn) submitBtn.disabled = true;
          if (emailInput) emailInput.disabled = true;
        } else {
          slotsEl.textContent = 'Linked accounts: ' + accepted + '/' + maxLinks + '. You can invite ' + available + ' more.';
          if (submitBtn) submitBtn.disabled = false;
          if (emailInput) emailInput.disabled = false;
        }
      }

      function showEmptyIfNeeded(table, type) {
        const rows = table.querySelectorAll('[data-link-row]');
        const existing = table.querySelector('[data-link-empty]');
        if (rows.length === 0 && !existing) {
          const empty = document.createElement('div');
          empty.className = 'table-row linked-row';
          empty.setAttribute('data-link-empty', type);
          const labels = { incoming: 'No incoming requests.', outgoing: 'No pending requests.', accepted: 'No linked accounts yet.' };
          empty.innerHTML = '<div class="muted small">' + labels[type] + '</div><div></div>';
          table.appendChild(empty);
        }
      }

      function removeRow(row, table, type) {
        row.remove();
        showEmptyIfNeeded(table, type);
      }

      async function handleLinkAction(e) {
        e.preventDefault();
        const form = e.target.closest('form');
        const btn = form.querySelector('button[type="submit"]');
        if (btn) btn.disabled = true;

        try {
          const data = new URLSearchParams(new FormData(form));
          const r = await fetch(form.getAttribute('action'), {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'Accept': 'application/json', 'X-CSRF-Token': csrfToken },
            body: data
          });
          const json = await r.json();
          if (!r.ok || !json.ok) {
            showLinkFeedback('error', json.message || 'Something went wrong.');
            if (btn) btn.disabled = false;
            return;
          }

          showLinkFeedback('success', json.message);
          const row = form.closest('[data-link-row]');
          if (!row) return;

          const action = form.querySelector('input[name="action"]');
          if (action && action.value === 'accept') {
            const acceptedTable = document.querySelector('[data-accepted-table]');
            const incomingTable = document.querySelector('[data-incoming-table]');
            const emptyAccepted = acceptedTable.querySelector('[data-link-empty]');
            if (emptyAccepted) emptyAccepted.remove();

            const email = row.querySelector('.table-email').textContent;
            const linkId = form.querySelector('input[name="request_id"]').value;
            const newRow = document.createElement('div');
            newRow.className = 'table-row linked-row';
            newRow.setAttribute('data-link-row', linkId);
            newRow.innerHTML = '<div class="table-email">' + email.replace(/</g, '&lt;') + '</div>' +
              '<div style="text-align: right;">' +
                '<form action="/settings/link/remove" method="POST" class="inline-form" data-link-action>' +
                  '<input type="hidden" name="_csrf" value="' + csrfToken + '">' +
                  '<input type="hidden" name="link_id" value="' + linkId + '">' +
                  '<button type="submit" class="ghost danger">Remove</button>' +
                '</form>' +
              '</div>';
            newRow.querySelector('[data-link-action]').addEventListener('submit', handleLinkAction);
            acceptedTable.appendChild(newRow);

            row.remove();
            showEmptyIfNeeded(incomingTable, 'incoming');
          } else {
            const table = row.closest('[data-incoming-table], [data-outgoing-table], [data-accepted-table]');
            const type = table.hasAttribute('data-incoming-table') ? 'incoming'
              : table.hasAttribute('data-outgoing-table') ? 'outgoing' : 'accepted';
            removeRow(row, table, type);
          }
          updateLinkSlots();
        } catch (err) {
          console.error('Link action failed', err);
          showLinkFeedback('error', 'Something went wrong.');
          if (btn) btn.disabled = false;
        }
      }

      document.querySelectorAll('[data-link-action]').forEach((form) => {
        form.addEventListener('submit', handleLinkAction);
      });

      // --- Send link request via fetch ---
      const linkRequestForm = document.querySelector('[data-link-request-form]');
      if (linkRequestForm) {
        linkRequestForm.addEventListener('submit', async (e) => {
          e.preventDefault();
          const btn = linkRequestForm.querySelector('button[type="submit"]');
          const emailInput = linkRequestForm.querySelector('input[name="email"]');
          if (btn) btn.disabled = true;

          try {
            const data = new URLSearchParams(new FormData(linkRequestForm));
            const r = await fetch(linkRequestForm.action, {
              method: 'POST',
              headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'Accept': 'application/json', 'X-CSRF-Token': csrfToken },
              body: data
            });
            const json = await r.json();
            if (!r.ok || !json.ok) {
              showLinkFeedback('error', json.message || 'Something went wrong.');
              if (btn) btn.disabled = false;
              return;
            }

            showLinkFeedback('success', json.message);
            emailInput.value = '';
            if (btn) btn.disabled = false;

            if (json.request) {
              const outgoing = document.querySelector('[data-outgoing-table]');
              const emptyOutgoing = outgoing.querySelector('[data-link-empty]');
              if (emptyOutgoing) emptyOutgoing.remove();

              const date = json.request.created_at ? json.request.created_at.slice(0, 10) : '';
              const newRow = document.createElement('div');
              newRow.className = 'table-row linked-row';
              newRow.setAttribute('data-link-row', json.request.id);
              newRow.innerHTML = '<div>' +
                  '<div class="table-email">' + json.request.email.replace(/</g, '&lt;') + '</div>' +
                  '<div class="muted small">Sent ' + date + '</div>' +
                '</div>' +
                '<div class="table-actions">' +
                  '<form action="/settings/link/remove" method="POST" class="inline-form" data-link-action>' +
                    '<input type="hidden" name="_csrf" value="' + csrfToken + '">' +
                    '<input type="hidden" name="link_id" value="' + json.request.id + '">' +
                    '<button type="submit" class="ghost danger">Cancel</button>' +
                  '</form>' +
                '</div>';
              newRow.querySelector('[data-link-action]').addEventListener('submit', handleLinkAction);
              outgoing.appendChild(newRow);
            }
          } catch (err) {
            console.error('Link request failed', err);
            showLinkFeedback('error', 'Something went wrong.');
            if (btn) btn.disabled = false;
          }
        });
      }
    })();
  </script>
<%- include('partials/footer') %>
