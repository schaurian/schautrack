# =============================================================================
# SCHAUTRACK ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and configure as needed.
# Variables can also be set via /admin settings page (DB values override defaults,
# but env vars always take precedence).
#
# Convention: only the REQUIRED block and the POSTGRES block (used by the
# bundled docker-compose) are uncommented. Uncomment any other line to enable
# that feature.

# =============================================================================
# REQUIRED
# =============================================================================

# PostgreSQL connection string
DATABASE_URL=postgresql://schautrack:schautrack@db:5432/schautrack

# Random secret for session encryption
SESSION_SECRET=please-change-me

# =============================================================================
# GENERAL
# =============================================================================

# Port to listen on (default: 3000)
# PORT=3000

# Base URL for SEO meta tags (canonical, Open Graph, etc.)
# Leave blank to auto-detect from request host
# BASE_URL=https://schautrack.com

# Email that gets access to /admin page
# ADMIN_EMAIL=

# Contact email shown on support/error pages
# SUPPORT_EMAIL=

# =============================================================================
# AI FEATURES
# =============================================================================
# Photo-based calorie estimation with support for OpenAI, Claude, and Ollama.

# AI provider to use: openai, claude, or ollama. Required to enable AI features.
# AI_PROVIDER=

# Global API key (fallback when users don't have their own)
# AI_KEY=

# Random 32-byte hex string for encrypting API keys
# AI_KEY_ENCRYPTION_SECRET=

# Custom endpoint override (e.g., http://your-ollama-host:11434/v1). Leave blank to use provider defaults.
# AI_ENDPOINT=

# Specify AI model to use (e.g., gpt-4o, claude-sonnet-4-5-20250929, gemma3:12b). Required for OpenAI and Claude.
# AI_MODEL=

# Daily limit for AI requests per user when using the global key (0 = unlimited).
# Default when unset: unlimited (no cap). The Helm chart sets this to 10 by default.
# AI_DAILY_LIMIT=10

# Note: Ollama models must be downloaded before use. The docker-compose setup
# automatically pulls the model specified in AI_MODEL. Models specified only
# in API requests will fail if not pre-downloaded.

# =============================================================================
# FEATURES
# =============================================================================

# Enable barcode scanning via OpenFoodFacts (default: true, set 'false' to disable)
# ENABLE_BARCODE=true

# Check GitHub for a newer release so the footer can flag an outdated instance
# (default: true). Set 'false' to opt out of the outbound request to
# api.github.com — recommended for privacy-sensitive or air-gapped self-hosts.
# UPDATE_CHECK_ENABLED=true

# =============================================================================
# OIDC / SSO
# =============================================================================
# Single Sign-On via an OpenID Connect provider (Google, Authentik, Keycloak, etc.).
# Set OIDC_ISSUER + OIDC_CLIENT_ID + OIDC_CLIENT_SECRET to enable.
# Add <BASE_URL>/auth/oidc/callback as a redirect URI in your provider.

# Issuer URL (e.g., https://accounts.google.com). Enables OIDC when set.
# OIDC_ISSUER=

# OAuth2 client ID and secret
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=

# Button label (default: capitalized brand inferred from issuer host)
# OIDC_LABEL=

# Require invite code for OIDC registration (default: OIDC bypasses invite-only)
# OIDC_REQUIRE_INVITE=false

# Callback URL (default: auto-built as <BASE_URL>/auth/oidc/callback)
# OIDC_REDIRECT_URL=

# =============================================================================
# PASSKEYS (WebAuthn)
# =============================================================================
# Passwordless login with biometric verification. Setting PASSKEYS_RP_ID enables
# the feature. The RP ID gets baked into every registered passkey — once users
# have registered, changing it invalidates all existing passkeys.

# Relying Party ID — your domain only (no scheme, no port, no path).
# Examples: schautrack.com, staging.schautrack.com
# PASSKEYS_RP_ID=

# Display name shown in browser/OS passkey prompts (default: Schautrack)
# PASSKEYS_RP_NAME=Schautrack

# Allowed origins, comma-separated, full URLs with scheme.
# Defaults to https://<PASSKEYS_RP_ID>. Set this when the same RP ID is served
# from multiple URLs (e.g., www + apex, or an Android WebView origin).
# PASSKEYS_RP_ORIGINS=https://schautrack.com,https://www.schautrack.com

# =============================================================================
# REGISTRATION
# =============================================================================

# Registration mode: 'open' (default, anyone can register) or 'false'/'invite' (requires invite code)
# Can also be set via /admin settings page
# ENABLE_REGISTRATION=open

# =============================================================================
# SMTP (Transactional Email)
# =============================================================================
# Enables all transactional email flows: password reset, registration email
# verification, email-change verification, and 2FA reset. Without SMTP, none
# of these flows can deliver their codes.

# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# From address for emails (defaults to SUPPORT_EMAIL if not set)
# SMTP_FROM=
# SMTP_SECURE=false

# =============================================================================
# LEGAL PAGES
# =============================================================================

# Set to 'true' to enable /imprint, /privacy, /terms
# ENABLE_LEGAL=false

# URL for imprint link (default: /imprint)
# IMPRINT_URL=/imprint

# Full name and address (use \n for line breaks)
# Example: IMPRINT_ADDRESS=John Doe\n123 Main St\n12345 City\nCountry
# IMPRINT_ADDRESS=

# Contact email (rendered as SVG for spam protection)
# IMPRINT_EMAIL=

# =============================================================================
# POSTGRES (docker-compose)
# =============================================================================
# These are used by the Postgres container in docker-compose.yml.
# Must match the credentials in DATABASE_URL above.

POSTGRES_DB=schautrack
POSTGRES_USER=schautrack
POSTGRES_PASSWORD=schautrack

# =============================================================================
# SECURITY
# =============================================================================

# Trust X-Forwarded-For headers for rate limiting (default: true for reverse proxy setups)
# Set to 'false' if the app is directly exposed without a proxy
# TRUST_PROXY=true

# Max authentication attempts per 15 minutes per IP (default: 10)
# RATE_LIMIT_AUTH=10

# Step-up auth grace window — how long after primary login (or a fresh
# step-up) sensitive auth-method changes are accepted without re-prompting
# the user (delete passkey, disable 2FA, change password/email, etc.).
# Any value parsed by Go's time.ParseDuration. Default: 30m.
# STEP_UP_TTL=30m

# CAPTCHA (SVG, self-hosted, no third-party service) protects login,
# registration, and verification-email resend against brute-force abuse.
# It is always on and needs no configuration.
#
# TEST-ONLY ESCAPE HATCH — DO NOT SET IN PRODUCTION.
# When 'true', ANY non-empty CAPTCHA answer is accepted, disabling
# brute-force protection entirely. It exists solely so the E2E test
# suite (compose.test.yml) can drive auth flows. Default: unset (off).
# CAPTCHA_BYPASS=true

# =============================================================================
# SEO / DEPLOYMENT
# =============================================================================

# Set to 'true' to allow search engine indexing (default: noindex for self-hosters)
# ROBOTS_INDEX=true
